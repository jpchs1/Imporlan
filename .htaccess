RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================
# 410 GONE — WordPress legacy query params
# ============================================
RewriteCond %{QUERY_STRING} (^|&)(p|page_id|cat|tag|author|attachment_id|preview|preview_id|wc-ajax|add-to-cart|removed_item)= [NC]
RewriteRule ^ - [R=410,L]

# ============================================
# 410 GONE — WordPress legacy paths
# ============================================
RewriteRule ^feed(/.*)?$ - [R=410,L]
RewriteRule ^author(/.*)?$ - [R=410,L]
RewriteRule ^category(/.*)?$ - [R=410,L]
RewriteRule ^tag(/.*)?$ - [R=410,L]
RewriteRule ^wp-json(/.*)?$ - [R=410,L]
RewriteRule ^wp-login\.php$ - [R=410,L]
RewriteRule ^wp-config\.php$ - [R=410,L]
RewriteRule ^wp-cron\.php$ - [R=410,L]
RewriteRule ^wp-settings\.php$ - [R=410,L]
RewriteRule ^wp-load\.php$ - [R=410,L]
RewriteRule ^wp-blog-header\.php$ - [R=410,L]
RewriteRule ^wp-trackback\.php$ - [R=410,L]
RewriteRule ^wp-signup\.php$ - [R=410,L]
RewriteRule ^wp-activate\.php$ - [R=410,L]
RewriteRule ^wp-content(/.*)?$ - [R=410,L]
RewriteRule ^wp-includes(/.*)?$ - [R=410,L]
RewriteRule ^wp-admin(/.*)?$ - [R=410,L]
RewriteRule ^readme\.html$ - [R=410,L]
RewriteRule ^license\.txt$ - [R=410,L]
RewriteRule ^xmlrpc\.php$ - [R=410,L]
RewriteRule ^comments(/.*)?$ - [R=410,L]
RewriteRule ^trackback(/.*)?$ - [R=410,L]
RewriteRule ^[0-9]{4}/[0-9]{2}(/.*)?$ - [R=410,L]

# 301 Redirects: /pages/ -> /importaciones/
RedirectMatch 301 ^/pages/(.*)$ /importaciones/$1

# 301 Redirect: Consolidate duplicate lanchas-usadas page (SEO cannibalization fix)
RedirectMatch 301 ^/lanchas-usadas-en-chile-2(/.*)?$ /lanchas-usadas/

RewriteBase /

# 301 Redirects: TOUREVO pages moved to tourevo.cl
RewriteRule ^en(/.*)?$ https://tourevo.cl/en$1 [R=301,L]
RewriteRule ^br(/.*)?$ https://tourevo.cl/br$1 [R=301,L]

# 301 Redirects: CDSKI pages moved to clasesdeski.cl
RewriteRule ^es(/.*)?$ https://clasesdeski.cl/es$1 [R=301,L]
RewriteRule ^pt(/.*)?$ https://clasesdeski.cl/pt$1 [R=301,L]

# Cotizador Importacion - serve PHP
RewriteRule ^cotizador-importacion/?$ /cotizador-importacion/index.php [L]

# Simulacion Cotizacion - serve PHP
RewriteRule ^simulacion-cotizacion/?$ /simulacion-cotizacion/index.php [L]

# Marketplace clean URLs
RewriteRule ^marketplace/embarcacion/([0-9]+)/?.*$ /marketplace/embarcacion.php [L]
RewriteRule ^marketplace/publicar/?$ /marketplace.html [L]
RewriteRule ^marketplace/?$ /marketplace.html [L]

RewriteCond %{REQUEST_URI} ^/panel [OR]
RewriteCond %{REQUEST_URI} ^/api [OR]
RewriteCond %{REQUEST_URI} ^/pago [OR]
RewriteCond %{REQUEST_URI} ^/test
RewriteRule ^ - [L]

# ============================================
# CUSTOM 404 — replace SPA catch-all
# ============================================
# Previously served index.html for all unknown URLs (Soft 404).
# Now returns a proper HTTP 404 with a noindex page.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ - [R=404,L]

ErrorDocument 404 /404.html

# ============================================
# CORE WEB VITALS OPTIMIZATIONS 2026
# ============================================

# Enable GZIP/Brotli compression for all text-based content
<IfModule mod_deflate.c>
  SetOutputFilter DEFLATE
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
  AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
  AddOutputFilterByType DEFLATE application/vnd.ms-fontobject application/x-font-ttf
  AddOutputFilterByType DEFLATE font/opentype font/ttf font/eot font/otf
  AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
  
  # Remove browser bugs for old browsers
  BrowserMatch ^Mozilla/4 gzip-only-text/html
  BrowserMatch ^Mozilla/4\.0[678] no-gzip
  BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
  
  # Don't compress already compressed files
  SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif)$ no-gzip dont-vary
</IfModule>

# Browser caching for static assets
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Images - cache for 1 year
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  
  # CSS and JavaScript - cache for 1 week (revalidate on deploy)
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
  ExpiresByType text/javascript "access plus 1 week"
  
  # Fonts - cache for 1 year
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
  
  # HTML - short cache for dynamic content
  ExpiresByType text/html "access plus 1 hour"
  
  # Default
  ExpiresDefault "access plus 1 month"
</IfModule>

# Cache-Control headers
<IfModule mod_headers.c>
  # Cache images and fonts for 1 year (rarely change)
  <FilesMatch "\.(ico|pdf|flv|jpg|jpeg|png|gif|webp|swf|woff|woff2)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
  
  # JS and CSS - cache for 1 week with revalidation (changes on deploy)
  <FilesMatch "\.(js|css)$">
    Header set Cache-Control "max-age=604800, public, must-revalidate"
  </FilesMatch>
  
  # HTML files - no cache (always fetch fresh)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
  
  # PHP files - no cache
  <FilesMatch "\.(php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
  
  # Enable Keep-Alive
  Header set Connection keep-alive
</IfModule>

# Add WebP MIME type
<IfModule mod_mime.c>
  AddType image/webp .webp
</IfModule>

# ETags for cache validation (enabled for JS/CSS revalidation)
FileETag MTime Size

# ======================================================================
# ANTI-SPAM & SECURITY - IMPORLAN.CL
# ======================================================================

# --- Security Headers ---
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header set Permissions-Policy "geolocation=(self), microphone=(), camera=()"
  Header set Content-Security-Policy "default-src 'self' https:; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://apis.google.com https://accounts.google.com https://www.gstatic.com https://cdn.jsdelivr.net https://unpkg.com https://api.qrserver.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://accounts.google.com https://unpkg.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data: https: blob:; connect-src 'self' https: wss:; frame-src https://accounts.google.com https://www.google.com https://webpay3gint.transbank.cl https://webpay3g.transbank.cl; object-src 'none'; base-uri 'self'; form-action 'self' https://webpay3gint.transbank.cl https://webpay3g.transbank.cl"
</IfModule>

# --- Block access to sensitive files ---
<FilesMatch "(^#.*#|\.(bak|conf|dist|fla|in[ci]|log|psd|sh|sql|sw[op])|~)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# --- Protect config and credentials files ---
<FilesMatch "(config\.php|db_config\.php|config_api\.php|credentials\.php|credentials_config\.php|\.env|\.gitignore)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
  </IfModule>
</FilesMatch>

# --- Block PHP execution EVERYWHERE except /api/ and allowed PHP files ---
# This prevents attackers from uploading and executing PHP in random directories
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Allow PHP in /api/ directory (legitimate API endpoints)
  RewriteCond %{REQUEST_URI} ^/api/ [NC]
  RewriteRule ^ - [L]

  # Allow specific PHP files in known locations
  RewriteCond %{REQUEST_URI} ^/cotizador-importacion/index\.php$ [OR]
  RewriteCond %{REQUEST_URI} ^/simulacion-cotizacion/index\.php$ [OR]
  RewriteCond %{REQUEST_URI} ^/marketplace/embarcacion\.php$ [OR]
  RewriteCond %{REQUEST_URI} ^/marketplace/publicar/index\.php$
  RewriteRule ^ - [L]

  # BLOCK any other .php file execution (prevents injected malware)
  RewriteRule \.php$ - [F,L]
</IfModule>

# --- Block malicious bots (ahrefs/semrush unblocked for SEO monitoring) ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTP_USER_AGENT} (mj12bot|dotbot|blexbot|rogerbot|megaindex|seopowersuite) [NC]
  RewriteRule .* - [F,L]
</IfModule>

# --- Block suspicious URL patterns (common malware paths) ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Block random directory names that look like malware injection
  RewriteCond %{REQUEST_URI} ^/[a-z0-9]{6,12}/[a-z0-9]{6,12}\.php [NC]
  RewriteRule ^ - [F,L]
  # Block common backdoor filenames
  RewriteCond %{REQUEST_URI} (shell|c99|r57|wso|alfa|adminer|phpspy|b374k|weevely|mini\.php) [NC]
  RewriteRule ^ - [F,L]
  # Block wp-* paths (not a WordPress site)
  RewriteCond %{REQUEST_URI} ^/wp-(admin|login|includes|content) [NC]
  RewriteRule ^ - [F,L]
  # Block xmlrpc.php (common attack target)
  RewriteRule ^xmlrpc\.php$ - [F,L]
</IfModule>

# --- Block file upload to non-API paths ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} (PUT|POST) [NC]
  RewriteCond %{REQUEST_URI} !^/api/ [NC]
  RewriteCond %{REQUEST_URI} \.php$ [NC]
  RewriteRule ^ - [F,L]
</IfModule>

# --- Prevent directory browsing ---
Options -Indexes -ExecCGI

# --- Disable server signature ---
ServerSignature Off

# --- Restrict HTTP methods ---
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK|DEBUG) [NC]
  RewriteRule ^ - [F,L]
</IfModule>

# ======================================================================
# END ANTI-SPAM & SECURITY
# ======================================================================

# php -- BEGIN cPanel-generated handler, do not edit
# Set the "ea-php74" package as the default "PHP" programming language.
<IfModule mime_module>
  AddHandler application/x-httpd-ea-php74 .php .php7 .phtml
</IfModule>
# php -- END cPanel-generated handler, do not edit

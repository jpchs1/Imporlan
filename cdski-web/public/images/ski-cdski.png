.cdski-hp-discover-header{margin-bottom:40px;}
.cdski-hp-label{display:inline-block;font-size:12px;font-weight:700;letter-spacing:3px;color:#c8a951;text-transform:uppercase;margin-bottom:10px;}
.cdski-hp-discover-header h2{font-size:32px;font-weight:700;color:#222;margin:10px 0;}
.cdski-hp-discover-header p{font-size:16px;color:#666;max-width:600px;margin:0 auto;}
.cdski-hp-cards-grid{display:grid!important;grid-template-columns:repeat(3,1fr)!important;gap:20px!important;max-width:1000px!important;margin:0 auto!important;width:100%!important;}
.cdski-hp-card{display:block!important;background:#fff;border-radius:12px;padding:30px 20px;text-decoration:none!important;color:#333!important;box-shadow:0 2px 12px rgba(0,0,0,.08);transition:transform .25s ease,box-shadow .25s ease;text-align:center;position:relative;}
.cdski-hp-card:hover{transform:translateY(-4px);box-shadow:0 8px 25px rgba(0,0,0,.12);}
.cdski-hp-card-icon{display:block;font-size:32px;margin-bottom:12px;color:#c8a951;}
.cdski-hp-card h3{font-size:18px;font-weight:700;margin:0 0 8px;color:#222;}
.cdski-hp-card p{font-size:14px;color:#666;margin:0 0 12px;line-height:1.5;}
.cdski-hp-card-arrow{display:inline-block;font-size:18px;color:#c8a951;transition:transform .2s;}
.cdski-hp-card:hover .cdski-hp-card-arrow{transform:translateX(4px);}
.cdski-hp-exp-cta{background:linear-gradient(135deg,#1a1a2e 0%,#16213e 100%);padding:60px 0;color:#fff;}
.cdski-hp-exp-inner{display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;}
.cdski-hp-exp-text{flex:1;min-width:280px;}
.cdski-hp-exp-text h2{font-size:28px;font-weight:700;color:#fff;margin:0 0 15px;}
.cdski-hp-exp-text p{font-size:16px;color:rgba(255,255,255,.85);line-height:1.6;margin:0;}
.cdski-hp-exp-actions{display:flex;gap:15px;flex-wrap:wrap;align-items:center;}
.cdski-btn{display:inline-block;padding:14px 28px;border-radius:8px;font-size:15px;font-weight:600;text-decoration:none!important;transition:all .25s ease;cursor:pointer;text-align:center;}
.cdski-btn-primary{background:#c8a951;color:#fff!important;border:2px solid #c8a951;}
.cdski-btn-primary:hover{background:#b8982e;border-color:#b8982e;}
.cdski-btn-whatsapp{background:#25d366;color:#fff!important;border:2px solid #25d366;}
.cdski-btn-whatsapp:hover{background:#1da851;border-color:#1da851;}
.cdski-btn-outline{background:transparent;color:#c8a951!important;border:2px solid #c8a951;}
.cdski-btn-outline:hover{background:#c8a951;color:#fff!important;}
.cdski-mega-menu{position:relative!important;}
.cdski-mega-menu>.sub-menu.cdski-dropdown{display:none;position:absolute;top:100%;left:0;background:#fff;min-width:220px;box-shadow:0 4px 20px rgba(0,0,0,.15);border-radius:8px;padding:10px 0;z-index:9999;list-style:none!important;}
.cdski-mega-menu:hover>.sub-menu.cdski-dropdown{display:block!important;}
.cdski-dropdown .menu-item{display:block!important;}
.cdski-dropdown .menu-item a{display:block!important;padding:8px 20px!important;color:#333!important;text-decoration:none!important;font-size:14px!important;white-space:nowrap;transition:background .2s,color .2s;}
.cdski-dropdown .menu-item a:hover{background:#f5f0e0!important;color:#c8a951!important;}
@media(max-width:480px){.cdski-hp-card{padding:20px 15px;}.cdski-btn{padding:12px 22px;font-size:14px;}.cdski-hp-exp-actions{flex-direction:column;width:100%;}.cdski-hp-exp-actions .cdski-btn{width:100%;box-sizing:border-box;}}

# ==========================================
# CDSKI - Redirects 301 for SEO preservation
# Old WordPress URLs → New static site
# ==========================================

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Language detection for root ──
# Redirect bare domain to Spanish (302 so Google indexes /es/ as canonical)
RewriteRule ^$ /es/ [R=302,L]

# ── Old WordPress blog post redirects → new site sections ──
RewriteRule ^heliski-chile/?$ /es/#blog [R=301,L]
RewriteRule ^a-la-nieve-en-helicoptero/?$ /es/#blog [R=301,L]
RewriteRule ^centro-de-ski-el-colorado/?$ /es/#blog [R=301,L]
RewriteRule ^centro-de-ski-la-parva/?$ /es/#blog [R=301,L]
RewriteRule ^valle-nevado-centro-de-ski/?$ /es/#blog [R=301,L]
RewriteRule ^clases-de-ski/?$ /es/#services [R=301,L]
RewriteRule ^clases-de-snowboard/?$ /es/#services [R=301,L]
RewriteRule ^10-centros-de-ski-en-chile/?$ /es/#blog [R=301,L]
RewriteRule ^consejos-primer-dia-nieve/?$ /es/#blog [R=301,L]
RewriteRule ^donde-alojar-en-la-nieve/?$ /es/#blog [R=301,L]
RewriteRule ^rental/?$ /es/#blog [R=301,L]
RewriteRule ^experiencias/?$ /es/#services [R=301,L]
RewriteRule ^services/childrens-snowboard-lessons/?$ /es/#services [R=301,L]

# Portuguese content redirects
RewriteRule ^aulas-de-ski/?$ /pt/#blog [R=301,L]
RewriteRule ^aulas-de-snowboard-2/?$ /pt/#blog [R=301,L]

# Old pricing pages
RewriteRule ^snow-day/?$ /es/#pricing [R=301,L]
RewriteRule ^precios-clases-de-ski/?$ /es/#pricing [R=301,L]
RewriteRule ^precios/?$ /es/#pricing [R=301,L]

# Old "Explora CDSKI" pages
RewriteRule ^about-cdski/?$ /es/#blog [R=301,L]
RewriteRule ^nuestro-metodo/?$ /es/#blog [R=301,L]
RewriteRule ^seguridad-montana/?$ /es/#blog [R=301,L]
RewriteRule ^niveles/?$ /es/#blog [R=301,L]
RewriteRule ^experiencia-cdski/?$ /es/#blog [R=301,L]
RewriteRule ^clases-ski-snowboard/?$ /es/#services [R=301,L]

# Old payment/booking pages
RewriteRule ^PAGO/?$ /es/#contact [R=301,L]
RewriteRule ^pago/?$ /es/#contact [R=301,L]
RewriteRule ^agendar-una-clase-consultas/?$ /es/#contact [R=301,L]

# Old service pages
RewriteRule ^servicios/?$ /es/#services [R=301,L]
RewriteRule ^nosotros/?$ /es/#blog [R=301,L]
RewriteRule ^clases/?$ /es/#services [R=301,L]
RewriteRule ^experiencia/?$ /es/#services [R=301,L]
RewriteRule ^experiencia-en-helicoptero/?$ /es/#blog [R=301,L]
RewriteRule ^viajes-grupales/?$ /es/#services [R=301,L]
RewriteRule ^group-trips/?$ /en/#services [R=301,L]
RewriteRule ^reviews/?$ /es/#testimonials [R=301,L]
RewriteRule ^dejanos-tu-resena/?$ /es/#testimonials [R=301,L]
RewriteRule ^noticias/?$ /es/#blog [R=301,L]

# Old WooCommerce/system pages → home
RewriteRule ^cart/?$ /es/ [R=301,L]
RewriteRule ^checkout/?$ /es/ [R=301,L]
RewriteRule ^my-account/?$ /es/ [R=301,L]
RewriteRule ^shop/?$ /es/ [R=301,L]
RewriteRule ^tienda/?$ /es/ [R=301,L]
RewriteRule ^booked/?$ /es/#contact [R=301,L]

# Old tariff PDF → pricing section
RewriteRule ^wp-content/uploads/2016/08/TARIFAS-CDSKI-2019.pdf$ /es/#pricing [R=301,L]

# ── Performance headers ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

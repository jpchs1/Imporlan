# ==========================================
# CDSKI - Redirects 301 for SEO preservation
# Old WordPress URLs → New static site
# ==========================================

RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Root serves Spanish content directly (no redirect) ──
# clasesdeski.cl/ = main page (Spanish)
# clasesdeski.cl/en/ = English
# clasesdeski.cl/pt/ = Portuguese

# ── Old WordPress blog post redirects → new site sections ──
RewriteRule ^heliski-chile/?$ /#blog [R=301,L]
RewriteRule ^a-la-nieve-en-helicoptero/?$ /#blog [R=301,L]
RewriteRule ^centro-de-ski-el-colorado/?$ /#blog [R=301,L]
RewriteRule ^centro-de-ski-la-parva/?$ /#blog [R=301,L]
RewriteRule ^valle-nevado-centro-de-ski/?$ /#blog [R=301,L]
RewriteRule ^clases-de-ski/?$ /#services [R=301,L]
RewriteRule ^clases-de-snowboard/?$ /#services [R=301,L]
RewriteRule ^10-centros-de-ski-en-chile/?$ /#blog [R=301,L]
RewriteRule ^consejos-primer-dia-nieve/?$ /#blog [R=301,L]
RewriteRule ^donde-alojar-en-la-nieve/?$ /#blog [R=301,L]
RewriteRule ^rental/?$ /#blog [R=301,L]
RewriteRule ^experiencias/?$ /#services [R=301,L]
RewriteRule ^services/childrens-snowboard-lessons/?$ /#services [R=301,L]

# Portuguese content redirects
RewriteRule ^aulas-de-ski/?$ /pt/#blog [R=301,L]
RewriteRule ^aulas-de-snowboard-2/?$ /pt/#blog [R=301,L]

# Old pricing pages
RewriteRule ^snow-day/?$ /#pricing [R=301,L]
RewriteRule ^precios-clases-de-ski/?$ /#pricing [R=301,L]
RewriteRule ^precios/?$ /#pricing [R=301,L]

# Old "Explora CDSKI" pages
RewriteRule ^about-cdski/?$ /#blog [R=301,L]
RewriteRule ^nuestro-metodo/?$ /#blog [R=301,L]
RewriteRule ^seguridad-montana/?$ /#blog [R=301,L]
RewriteRule ^niveles/?$ /#blog [R=301,L]
RewriteRule ^experiencia-cdski/?$ /#blog [R=301,L]
RewriteRule ^clases-ski-snowboard/?$ /#services [R=301,L]

# Old payment/booking pages
RewriteRule ^PAGO/?$ /#contact [R=301,L]
RewriteRule ^pago/?$ /#contact [R=301,L]
RewriteRule ^agendar-una-clase-consultas/?$ /#contact [R=301,L]

# Old service pages
RewriteRule ^servicios/?$ /#services [R=301,L]
RewriteRule ^nosotros/?$ /#blog [R=301,L]
RewriteRule ^clases/?$ /#services [R=301,L]
RewriteRule ^experiencia/?$ /#services [R=301,L]
RewriteRule ^experiencia-en-helicoptero/?$ /#blog [R=301,L]
RewriteRule ^viajes-grupales/?$ /#services [R=301,L]
RewriteRule ^group-trips/?$ /en/#services [R=301,L]
RewriteRule ^reviews/?$ /#testimonials [R=301,L]
RewriteRule ^dejanos-tu-resena/?$ /#testimonials [R=301,L]
RewriteRule ^noticias/?$ /#blog [R=301,L]

# Old WooCommerce/system pages → home
RewriteRule ^cart/?$ / [R=301,L]
RewriteRule ^checkout/?$ / [R=301,L]
RewriteRule ^my-account/?$ / [R=301,L]
RewriteRule ^shop/?$ / [R=301,L]
RewriteRule ^tienda/?$ / [R=301,L]
RewriteRule ^booked/?$ /#contact [R=301,L]

# Old tariff PDF → pricing section
RewriteRule ^wp-content/uploads/2016/08/TARIFAS-CDSKI-2019.pdf$ /#pricing [R=301,L]

# ── Performance headers ──
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/html "access plus 1 hour"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
